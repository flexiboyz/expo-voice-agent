{
  "expo": {
    "name": "expo-voice-agent",
    "slug": "expo-voice-agent",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.flexiboyz.expovoiceagent",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "This app uses the microphone to capture your voice for speech recognition.",
        "NSSpeechRecognitionUsageDescription": "This app uses on-device speech recognition to transcribe your voice."
      }
    },
    "android": {
      "package": "com.flexiboyz.expovoiceagent",
      "permissions": ["RECORD_AUDIO"],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "@jamsch/expo-speech-recognition"
    ]
  }
}
